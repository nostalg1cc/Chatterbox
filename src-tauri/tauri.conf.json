{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Dislight",
  "version": "0.1.16",
  "identifier": "io.github.nostalg1cc.dislight",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Dislight",
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 560,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "script-src": "'self'",
        "style-src": "'self' 'unsafe-inline'",
        "img-src": "'self' data: blob: https://lapjrxdgcbdseskmyfru.supabase.co https://res.cloudinary.com",
        "media-src": "'self' blob: https://lapjrxdgcbdseskmyfru.supabase.co",
        "font-src": "'self' data:",
        "connect-src": "'self' ipc: http://ipc.localhost https://lapjrxdgcbdseskmyfru.supabase.co wss://lapjrxdgcbdseskmyfru.supabase.co https://res.cloudinary.com"
      },
      "devCsp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQwN0U4RDQ4OUU0ODAzRTgKUldUb0EwaWVTSTErMEtuRUhsUGhrazVDMFhCMnE4Q2Q5MjlhZGFSS1oxTUNCeWxPRlAxa01XNzMK",
      "endpoints": [
        "https://github.com/nostalg1cc/Chatterbox/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "quiet"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}